{
  "name": "@mazeballs/ctnet",
  "version": "0.1.4",
  "description": "A library for simulating continuous-time dynamical networks",
  "license": "Apache-2.0",
  "main": "dist/ctnet.js",
  "module": "dist/ctnet.mjs",
  "exports": {
    ".": {
      "import": "./dist/ctnet.mjs",
      "require": "./dist/ctnet.js"
    }
  },
  "files": [
    "dist",
    "src",
    "LICENSE",
    "wasm"
  ],
  "scripts": {
    "build": "rollup -c",
    "clean": "rm -rf dist/",
    "clean:all": "rm -rf dist/ node_modules/",
    "test": "npm run build && jest --testTimeout=15000",
    "test:browser": "npm run build && open tests/browser/runner.html",
    "test:wasm": "npm run build && node tests/check-wasm.js",
    "publish:patch": "npm version patch && npm publish",
    "publish:minor": "npm version minor && npm publish",
    "publish:alpha": "npm version prerelease --preid=alpha && npm publish --tag alpha",
    "prepublishOnly": "npm run build",
    "lint": "echo 'No linter configured yet'",
    "docs:prepare": "mkdir -p docs/{css,js,examples,api}",
    "docs:copy-demos": "cp -r demos/* docs/examples/ 2>/dev/null || echo 'No demos to copy'",
    "docs:copy-networks": "cp -r networks docs/networks 2>/dev/null || echo 'No networks to copy'",
    "docs:copy-lib": "mkdir -p docs/js && cp -r dist/* docs/js/",
    "docs:build": "npm run build && npm run docs:prepare && npm run docs:copy-demos && npm run docs:copy-networks && npm run docs:copy-lib",
    "docs:serve": "npx http-server docs",
    "docs:deploy": "npm run docs:build && gh-pages -d docs",
    "dev": "rollup -c -w"
  },
  "dependencies": {
    "@tensorflow/tfjs": "^4.1.0",
    "@tensorflow/tfjs-backend-wasm": "^4.1.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.2",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-terser": "^0.4.4",
    "jest": "^29.3.1",
    "rollup": "^3.7.5"
  },
  "keywords": [
    "neural-networks",
    "tensorflow",
    "simulation",
    "dynamical-systems",
    "browser"
  ],
  "author": "Mazeballs Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/danbri/mazeballs"
  },
  "publishConfig": {
    "access": "public"
  }
}
